# ============================================================
#  .env  —  SCRAP-CRAFTERS Server Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to version control.
# ============================================================

# ── PostgreSQL connection ──────────────────────────────────
# Option A: individual fields (recommended for local dev)
PGHOST=localhost
PGPORT=5432
PGDATABASE=scrapcrafters
PGUSER=postgres
PGPASSWORD=root123

# Option B: single connection URL (overrides individual fields if set)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/scrapcrafters

# ── JWT ───────────────────────────────────────────────────
# Use a long random string in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=scrap_crafters_super_secret_jwt_key_change_me_in_prod
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# React dev server origin for CORS
CLIENT_ORIGIN=http://localhost:3000

# ── File uploads ──────────────────────────────────────────
# Max file size in bytes  (default = 5 MB)
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
